// ===== Nokia 5510 Display Configuration =====
// USE D-LABELS (NOT GPIO NUMBERS)
#define SCLK_PIN  D1  // Serial Clock (GPIO5)
#define DIN_PIN   D2  // Data In (MOSI) (GPIO4)
#define DC_PIN    D5  // Data/Command (GPIO14)
#define CS_PIN    D6  // Chip Select (SCE) (GPIO12)
#define RST_PIN   D7  // Reset (GPIO13)

#define SCREEN_WIDTH  84
#define SCREEN_HEIGHT 48

// ===== Drawing Buffer =====
bool pixelBuffer[SCREEN_WIDTH][SCREEN_HEIGHT];
bool dirty = false;

// ===== Web Server =====
ESP8266WebServer server(80);

// Create display object
Adafruit_PCD8544 display = Adafruit_PCD8544(SCLK_PIN, DIN_PIN, DC_PIN, CS_PIN, RST_PIN);

