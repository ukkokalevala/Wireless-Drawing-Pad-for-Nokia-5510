// ============================================================
// ===== ESP8266 Server Functions =====
// ============================================================

void setup() {
  Serial.begin(115200);
  
  // Initialize Nokia 5510 display
  display.begin();
  display.setContrast(50);
  display.setRotation(2);
  display.clearDisplay();
  display.display();
  
  clearBuffer();
  renderBuffer();
  
  // Connect to WiFi
  Serial.print("Connecting to WiFi");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected!");
  Serial.print("IP address: ");
  Serial.println(WiFi.localIP());
  
  // Show IP on Nokia display
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(BLACK, WHITE);
  display.setCursor(0, 0);
  display.println("IP:");
  display.println(WiFi.localIP().toString());
  display.println("Draw on:");
  display.println(WiFi.localIP().toString());
  display.display();
  
  // Setup web server routes
  server.on("/", HTTP_GET, handleRoot);
  server.on("/draw", HTTP_POST, handleDraw);
  server.on("/clear", HTTP_GET, handleClear);
  
  server.begin();
  Serial.println("HTTP server started");
}

void loop() {
  server.handleClient();
  
  if (dirty) {
    renderBuffer();
    dirty = false;
  }
  
  // ===== AUTO-CLEAR AFTER INACTIVITY =====
  static unsigned long lastDrawTime = millis();
  
  // Check if screen has any pixels
  bool hasPixels = false;
  for (int x = 0; x < SCREEN_WIDTH; x++) {
    for (int y = 0; y < SCREEN_HEIGHT; y++) {
      if (pixelBuffer[x][y]) {
        hasPixels = true;
        break;
      }
    }
    if (hasPixels) break;
  }
  
  // Reset timer if there are pixels (user is drawing)
  if (hasPixels) {
    lastDrawTime = millis();
  }
  
  // Auto-clear after 30 seconds of no drawing AND empty screen
  if (!hasPixels && millis() - lastDrawTime > 30000) {
    clearBuffer();
    dirty = true;
    lastDrawTime = millis();
    Serial.println("Auto-cleared after inactivity");
  }
  // ===== END AUTO-CLEAR =====
  
  delay(10);
}

// ===== Web Handlers =====

void handleRoot() {
  server.send(200, "text/html", htmlPage);
}

void handleDraw() {
  if (server.hasArg("plain")) {
    String json = server.arg("plain");
    
    int startIndex = json.indexOf('[');
    int endIndex = json.indexOf(']');
    if (startIndex != -1 && endIndex != -1) {
      String pixelData = json.substring(startIndex + 1, endIndex);
      
      int count = 0;
      int pos = 0;
      while (pos < pixelData.length() && count < SCREEN_WIDTH * SCREEN_HEIGHT) {
        int nextComma = pixelData.indexOf(',', pos);
        String valueStr;
        if (nextComma != -1) {
          valueStr = pixelData.substring(pos, nextComma);
          pos = nextComma + 1;
        } else {
          valueStr = pixelData.substring(pos);
          pos = pixelData.length();
        }
        valueStr.trim();
        int value = valueStr.toInt();
        
        int x = count % SCREEN_WIDTH;
        int y = count / SCREEN_WIDTH;
        pixelBuffer[x][y] = (value == 1);
        count++;
      }
      
      dirty = true;
      server.send(200, "text/plain", "OK");
      return;
    }
  }
  server.send(400, "text/plain", "Bad Request");
}

void handleClear() {
  clearBuffer();
  dirty = true;
  server.send(200, "text/plain", "Cleared");
}

// ===== Display Buffer Functions =====

void clearBuffer() {
  for (int x = 0; x < SCREEN_WIDTH; x++) {
    for (int y = 0; y < SCREEN_HEIGHT; y++) {
      pixelBuffer[x][y] = false;
    }
  }
}

void renderBuffer() {
  display.clearDisplay();
  
  for (int x = 0; x < SCREEN_WIDTH; x++) {
    for (int y = 0; y < SCREEN_HEIGHT; y++) {
      if (pixelBuffer[x][y]) {
        display.drawPixel(x, y, BLACK);
      }
    }
  }
  
  display.display();
}
