                clientX = e.touches[0].clientX;
                clientY = e.touches[0].clientY;
                e.preventDefault();
            } else {
                clientX = e.clientX;
                clientY = e.clientY;
            }
            
            return {
                x: Math.max(0, Math.min(83, Math.floor((clientX - rect.left) * scaleX))),
                y: Math.max(0, Math.min(47, Math.floor((clientY - rect.top) * scaleY)))
