            const sy = (y0 < y1) ? 1 : -1;
            let err = dx - dy;

            while (true) {
                drawPixel(x0, y0, size);
                if (x0 === x1 && y0 === y1) break;
                const e2 = 2 * err;
                if (e2 > -dy) { err -= dy; x0 += sx; }
                if (e2 < dx) { err += dx; y0 += sy; }
            }
